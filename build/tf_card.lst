 204:lib/fatfs/src/tf_card.c **** 
 205:lib/fatfs/src/tf_card.c **** static
 206:lib/fatfs/src/tf_card.c **** int rcvr_datablock (	/* 1:OK, 0:Error */
 207:lib/fatfs/src/tf_card.c **** 	BYTE *buff,			/* Data buffer */
 208:lib/fatfs/src/tf_card.c **** 	UINT btr			/* Data block length (byte) */
 209:lib/fatfs/src/tf_card.c **** )
 210:lib/fatfs/src/tf_card.c **** {
 211:lib/fatfs/src/tf_card.c **** 	BYTE token;
GAS LISTING /var/folders/rt/4gvqv631095f64jvm7jfj_000000gn/T//ccRH6IFk.s 			page 12


 212:lib/fatfs/src/tf_card.c **** 
 213:lib/fatfs/src/tf_card.c **** 	tf_start_timer(200);
 214:lib/fatfs/src/tf_card.c **** 	do {							/* Wait for DataStart token in timeout of 200ms */
 215:lib/fatfs/src/tf_card.c **** 		token = xchg_spi(0xFF);
 216:lib/fatfs/src/tf_card.c **** 		/* This loop will take a time. Insert rot_rdq() here for multitask envilonment. */
 217:lib/fatfs/src/tf_card.c **** 	} while ((token == 0xFF) && tf_timer_done());
 218:lib/fatfs/src/tf_card.c **** 	if(token != 0xFE) return 0;		/* Function fails if invalid DataStart token or timeout */
 219:lib/fatfs/src/tf_card.c **** 
 220:lib/fatfs/src/tf_card.c **** 	rcvr_spi_multi(buff, btr);		/* Store trailing data to the buffer */
 221:lib/fatfs/src/tf_card.c **** 	xchg_spi(0xFF); xchg_spi(0xFF);			/* Discard CRC */
 222:lib/fatfs/src/tf_card.c **** 
 223:lib/fatfs/src/tf_card.c **** 	return 1;						/* Function succeeded */
 224:lib/fatfs/src/tf_card.c **** }
 225:lib/fatfs/src/tf_card.c **** 
 226:lib/fatfs/src/tf_card.c **** static
 227:lib/fatfs/src/tf_card.c **** int xmit_datablock (	/* 1:OK, 0:Failed */
 228:lib/fatfs/src/tf_card.c **** 	const BYTE *buff,	/* Ponter to 512 byte data to be sent */
 229:lib/fatfs/src/tf_card.c **** 	BYTE token			/* Token */
 230:lib/fatfs/src/tf_card.c **** )
 231:lib/fatfs/src/tf_card.c **** {
 232:lib/fatfs/src/tf_card.c **** 	BYTE resp;
 233:lib/fatfs/src/tf_card.c **** 
 234:lib/fatfs/src/tf_card.c **** 
 235:lib/fatfs/src/tf_card.c **** 	if (!wait_ready(500)) return 0;		/* Wait for card ready */
 236:lib/fatfs/src/tf_card.c **** 
 237:lib/fatfs/src/tf_card.c **** 	xchg_spi(token);					/* Send token */
 238:lib/fatfs/src/tf_card.c **** 	if (token != 0xFD) {				/* Send data if token is other than StopTran */
 239:lib/fatfs/src/tf_card.c **** 		xmit_spi_multi(buff, 512);		/* Data */
 240:lib/fatfs/src/tf_card.c **** 		xchg_spi(0xFF); xchg_spi(0xFF);	/* Dummy CRC */
 241:lib/fatfs/src/tf_card.c **** 
 242:lib/fatfs/src/tf_card.c **** 		resp = xchg_spi(0xFF);				/* Receive data resp */
 243:lib/fatfs/src/tf_card.c **** 		if ((resp & 0x1F) != 0x05) return 0;	/* Function fails if the data packet was not accepted */
 244:lib/fatfs/src/tf_card.c **** 	}
 245:lib/fatfs/src/tf_card.c **** 	return 1;
 246:lib/fatfs/src/tf_card.c **** }

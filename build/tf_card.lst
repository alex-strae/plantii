 148:lib/fatfs/src/tf_card.c **** 
 149:lib/fatfs/src/tf_card.c **** 	do {
 150:lib/fatfs/src/tf_card.c **** 		delta_mtime = get_timer_value();
 151:lib/fatfs/src/tf_card.c **** 		delta_mtime -=  start_mtime;
 152:lib/fatfs/src/tf_card.c **** 		d = xchg_spi(0xFF);
 153:lib/fatfs/src/tf_card.c **** 	}while((d != 0xFF) && (delta_mtime <(SystemCoreClock/4000.0 *wt )));
 154:lib/fatfs/src/tf_card.c **** 	/*
 155:lib/fatfs/src/tf_card.c **** 	
 156:lib/fatfs/src/tf_card.c **** 	BYTE d;
 157:lib/fatfs/src/tf_card.c **** 
 158:lib/fatfs/src/tf_card.c **** 	// Timer2 = wt;
 159:lib/fatfs/src/tf_card.c ****     delay_timer2 = wt;
 160:lib/fatfs/src/tf_card.c **** 	do {

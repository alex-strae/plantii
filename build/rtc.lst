  87:rtc.c         **** /*!
  88:rtc.c         ****     \brief      return the time entered by user, using Hyperterminal
  89:rtc.c         ****     \param[in]  none
  90:rtc.c         ****     \param[out] none
  91:rtc.c         ****     \retval     current time of RTC counter value
  92:rtc.c         **** */
  93:rtc.c         **** uint32_t time_regulate(void)
  94:rtc.c         **** {
  95:rtc.c         ****     uint32_t tmp_hh = 0xFF, tmp_mm = 0xFF, tmp_ss = 0xFF;
  96:rtc.c         **** 
  97:rtc.c         ****     printf("\r\n==============Time Settings=====================================");
  98:rtc.c         ****     printf("\r\n  Please Set Hours");
  99:rtc.c         **** 
 100:rtc.c         ****     while (tmp_hh == 0xFF){
 101:rtc.c         ****         tmp_hh = usart_scanf(23);
 102:rtc.c         ****     }
 103:rtc.c         ****     printf(":  %d", tmp_hh);
 104:rtc.c         ****     printf("\r\n  Please Set Minutes");
 105:rtc.c         ****     while (tmp_mm == 0xFF){
 106:rtc.c         ****         tmp_mm = usart_scanf(59);
 107:rtc.c         ****     }
 108:rtc.c         ****     printf(":  %d", tmp_mm);
 109:rtc.c         ****     printf("\r\n  Please Set Seconds");
 110:rtc.c         ****     while (tmp_ss == 0xFF){
 111:rtc.c         ****         tmp_ss = usart_scanf(59);
 112:rtc.c         ****     }
GAS LISTING /var/folders/rt/4gvqv631095f64jvm7jfj_000000gn/T//ccFQbxzL.s 			page 5


 113:rtc.c         ****     printf(":  %d", tmp_ss);
 114:rtc.c         **** 
 115:rtc.c         ****     /* return the value  store in RTC counter register */
 116:rtc.c         ****     return((tmp_hh*3600 + tmp_mm*60 + tmp_ss));
 117:rtc.c         **** }
 118:rtc.c         **** 
 119:rtc.c         **** /*!
 120:rtc.c         ****     \brief      adjust time 
 121:rtc.c         ****     \param[in]  none
 122:rtc.c         ****     \param[out] none
 123:rtc.c         ****     \retval     none
 124:rtc.c         **** */
 125:rtc.c         **** void time_adjust(void)
 126:rtc.c         **** {
 127:rtc.c         ****     /* wait until last write operation on RTC registers has finished */
 128:rtc.c         ****     rtc_lwoff_wait();
 129:rtc.c         ****     /* change the current time */
 130:rtc.c         ****     rtc_counter_set(time_regulate());
 131:rtc.c         ****     /* wait until last write operation on RTC registers has finished */
 132:rtc.c         ****     rtc_lwoff_wait();
 133:rtc.c         **** }
 134:rtc.c         **** 

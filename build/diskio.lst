  44:diskio.c      **** 
  45:diskio.c      ****     uint8_t response;
  46:diskio.c      ****     uint32_t timeout;
  47:diskio.c      **** 
  48:diskio.c      ****     // Startup delay + 80 dummy clocks
  49:diskio.c      ****     for (volatile uint32_t i = 0; i < 1000000; i++);
  50:diskio.c      ****     sd_cs_high();
  51:diskio.c      ****     for (uint8_t i = 0; i < 20; i++) spi0_txrx(0xFF);
  52:diskio.c      **** 
  53:diskio.c      ****     // CMD0 - reset card
  54:diskio.c      ****     uint8_t retry = 0;
  55:diskio.c      ****     do {
  56:diskio.c      ****         response = sd_send_cmd(0, 0);
  57:diskio.c      ****         sd_cs_high();
  58:diskio.c      ****         spi0_txrx(0xFF);
  59:diskio.c      ****     } while (response != 0x01 && ++retry < 10);
  60:diskio.c      **** 
  61:diskio.c      ****     if (response != 0x01) return STA_NOINIT;
  62:diskio.c      **** 
  63:diskio.c      ****     // CMD8 - check voltage range (required for SDHC)
  64:diskio.c      ****     response = sd_send_cmd(8, 0x1AA);
  65:diskio.c      ****     if (response == 0x01) {
  66:diskio.c      ****         // Read 4 byte R7 response
  67:diskio.c      ****         uint8_t r7[4];
  68:diskio.c      ****         for (int i = 0; i < 4; i++) r7[i] = spi0_txrx(0xFF);
  69:diskio.c      ****         sd_cs_high();
GAS LISTING /var/folders/rt/4gvqv631095f64jvm7jfj_000000gn/T//cchTxIV7.s 			page 5


  70:diskio.c      ****         spi0_txrx(0xFF);
  71:diskio.c      **** 
  72:diskio.c      ****         if (r7[2] == 0x01 && r7[3] == 0xAA) {
  73:diskio.c      ****             // SDHC - send ACMD41 with HCS bit
  74:diskio.c      ****             timeout = 10000;
  75:diskio.c      ****             do {
  76:diskio.c      ****                 sd_send_cmd(55, 0);  // APP_CMD
  77:diskio.c      ****                 sd_cs_high();
  78:diskio.c      ****                 spi0_txrx(0xFF);
  79:diskio.c      ****                 response = sd_send_cmd(41, 0x40000000); // HCS=1
  80:diskio.c      ****                 sd_cs_high();
  81:diskio.c      ****                 spi0_txrx(0xFF);
  82:diskio.c      ****             } while (response != 0x00 && --timeout);
  83:diskio.c      **** 
  84:diskio.c      ****             if (response != 0x00) return STA_NOINIT;
  85:diskio.c      **** 
  86:diskio.c      ****             // CMD58 - read OCR to confirm SDHC
  87:diskio.c      ****             response = sd_send_cmd(58, 0);
  88:diskio.c      ****             uint8_t ocr[4];
  89:diskio.c      ****             for (int i = 0; i < 4; i++) ocr[i] = spi0_txrx(0xFF);
  90:diskio.c      ****             sd_cs_high();
  91:diskio.c      ****             spi0_txrx(0xFF);
  92:diskio.c      **** 
  93:diskio.c      ****             CardType = (ocr[0] & 0x40) ? CT_SDHC : CT_SD2;
  94:diskio.c      ****         }
  95:diskio.c      ****     } else {
  96:diskio.c      ****         // SD v1 - send ACMD41 without HCS
  97:diskio.c      ****         sd_cs_high();
  98:diskio.c      ****         spi0_txrx(0xFF);
  99:diskio.c      **** 
 100:diskio.c      ****         timeout = 10000;
 101:diskio.c      ****         do {
 102:diskio.c      ****             sd_send_cmd(55, 0);
 103:diskio.c      ****             sd_cs_high();
 104:diskio.c      ****             spi0_txrx(0xFF);
 105:diskio.c      ****             response = sd_send_cmd(41, 0);
 106:diskio.c      ****             sd_cs_high();
 107:diskio.c      ****             spi0_txrx(0xFF);
 108:diskio.c      ****         } while (response != 0x00 && --timeout);
 109:diskio.c      **** 
 110:diskio.c      ****         CardType = CT_SD1;
 111:diskio.c      ****     }
 112:diskio.c      **** 
 113:diskio.c      ****     return (timeout == 0) ? STA_NOINIT : 0;
 114:diskio.c      **** }

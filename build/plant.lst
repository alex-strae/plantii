  94:plant.c       ****       int averageValueThisDay = 0;
  95:plant.c       ****       for (int i = 0; i < MAX_SUN_READINGS; i++)
  96:plant.c       ****       {
  97:plant.c       ****         averageValueThisDay += plant->sun[i].reading;
